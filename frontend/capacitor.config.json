{
  "appId": "com.hetupathways.app",
  "appName": "HevaPOS",
  "webDir": "build",
  "server": {
    "androidScheme": "https",
    "cleartext": false
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0f172a"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f172a",
      "showSpinner": false
    }
  "android": {
    "ignorePlugins": [
      "BluetoothLe"
    ]
  }
}
