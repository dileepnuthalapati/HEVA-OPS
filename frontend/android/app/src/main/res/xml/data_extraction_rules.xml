<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) uses data-extraction rules instead of fullBackupContent.
  We opt out of BOTH cloud backup and device-to-device transfer so a fresh
  APK install on a new device does NOT restore the previous user's session.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
