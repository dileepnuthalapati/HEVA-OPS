<?xml version="1.0" encoding="utf-8"?>
<!--
  Excludes all app storage from Google Auto-Backup. Without this rule, Android
  automatically backs up the WebView's localStorage (including `auth_token`
  and cached `user` JSON) to Google Drive and restores it when the APK is
  reinstalled — causing the "reinstalled APK auto-logs in as old user" bug.

  This file is referenced by android:fullBackupContent in AndroidManifest.xml
  on Android 6 → 11.
-->
<full-backup-content>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="external" />
</full-backup-content>
